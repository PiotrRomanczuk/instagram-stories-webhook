# 🌐 APP CONFIGURATION
# ------------------------------------------------------------------------------
# The base URL of your application.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# 🔐 LAYER 1: PRIMARY IDENTITY (NextAuth Google Auth)
# ------------------------------------------------------------------------------
# Only this email will be allowed to sign in.
ADMIN_EMAIL=admin@example.com

# Google OAuth Settings
# Get these from Google Cloud Console (APIs & Services > Credentials)
AUTH_GOOGLE_ID=your_google_client_id_here
AUTH_GOOGLE_SECRET=your_google_client_secret_here

# Used by NextAuth to encrypt cookies.
NEXTAUTH_SECRET="your_nextauth_secret_here"

# 🎭 LAYER 2: META INTEGRATION (Facebook / Instagram)
# ------------------------------------------------------------------------------
# Main NextAuth Facebook handles
AUTH_FACEBOOK_ID=your_fb_app_id
AUTH_FACEBOOK_SECRET=your_fb_app_secret

# Original Meta variables for scripts/direct API calls
NEXT_PUBLIC_FB_APP_ID=your_fb_app_id
FB_APP_SECRET=your_fb_app_secret
FB_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Manual Debug Token (if needed)
META_TOKEN_GEN=your_manual_token_here

# 🛡️ EXTERNAL SECURITY (Webhook & Cron)
# ------------------------------------------------------------------------------
# Header: x-webhook-secret
WEBHOOK_SECRET="your_webhook_secret_here"
# Header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="your_cron_secret_here"

# ⚡ DATABASE (Supabase)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Used by Auth.js Adapter & Admin Scripts
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret
SUPABASE_DATABASE_PASSWORD=your_db_password
