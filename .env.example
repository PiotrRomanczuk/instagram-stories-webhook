# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Authentication (Next Auth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret
# AUTH_SECRET is also used by newer versions of Auth.js
AUTH_SECRET=your-auth-secret

# Google OAuth
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Instagram API / Facebook
FACEBOOK_APP_ID=your-app-id
FACEBOOK_APP_SECRET=your-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/callback/facebook
NEXT_PUBLIC_FACEBOOK_APP_ID=your-app-id

# Token Encryption (AES-256-GCM, 32 bytes = 64 hex characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key

# Webhooks / Cron
CRON_SECRET=your-cron-secret
WEBHOOK_SECRET=your-webhook-secret

# Local Cron Runner (development only)
ENABLE_LOCAL_CRON=false
# Per-job overrides (uncomment to use):
# CRON_ENABLE_IDENTITY_AUDIT=true
# CRON_DISABLE_PROCESS=true

# Sentry
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# AI Analysis (Optional)
OPENAI_API_KEY=your-openai-api-key
